# Copy this file to .env for local development and fill in as needed.
# See README.md "Production deployment" for what's required in production.

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/elimuhubke_dev?schema=public"

# --- Auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Platform business rules ---
PLATFORM_COMMISSION_PERCENT="20"

# --- M-Pesa Daraja API (leave blank for sandbox mock mode) ---
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE="174379"
MPESA_PASSKEY=""
MPESA_STK_CALLBACK_URL="http://localhost:3000/api/mpesa/stk-callback"
MPESA_B2C_RESULT_URL="http://localhost:3000/api/mpesa/b2c-result"
MPESA_B2C_TIMEOUT_URL="http://localhost:3000/api/mpesa/b2c-timeout"
MPESA_INITIATOR_NAME=""
MPESA_INITIATOR_PASSWORD=""
MPESA_B2C_SHORTCODE=""

# --- Internal ---
PAYOUT_JOB_SECRET=""

# --- File storage (Cloudflare R2, leave blank for local disk fallback) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# --- Transactional email (Resend, leave blank to log emails to console) ---
RESEND_API_KEY=""
EMAIL_FROM="ElimuHubKE <onboarding@resend.dev>"
